# Luxafor Flag USB HID — allow non-root access
# Deployed to /etc/udev/rules.d/99-luxafor.rules
# hidraw device (for hidraw backend)
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="04d8", ATTRS{idProduct}=="f372", MODE="0666"
# USB device (for libusb backend used by python3-hid)
SUBSYSTEM=="usb", ATTR{idVendor}=="04d8", ATTR{idProduct}=="f372", MODE="0666"
