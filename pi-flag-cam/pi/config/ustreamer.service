[Unit]
Description=uStreamer MJPEG Video Streaming
After=network.target
Wants=network.target

[Service]
Type=simple
User=aarzner
ExecStart=/usr/bin/ustreamer \
    --device /dev/video0 \
    --resolution 1280x720 \
    --format MJPEG \
    --desired-fps 10 \
    --drop-same-frames 30 \
    --slowdown \
    --host 0.0.0.0 \
    --port 8081
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1

# Hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
