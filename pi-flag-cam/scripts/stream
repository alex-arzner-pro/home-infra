#!/usr/bin/env bash
# Pi Flag Cam — Open live camera stream in browser
# Usage: stream

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/config.sh"
URL="http://${PI_HOST}:${PI_CAM_PORT}/?action=stream"

echo "Opening stream: $URL"
xdg-open "$URL" 2>/dev/null || echo "Open in browser: $URL"
