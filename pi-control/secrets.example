# Copy to ~/.secrets/ and fill in real values
# chmod 600 ~/.secrets/*.env

# --- MikroTik Router ---
# ~/.secrets/mikrotik.env
MIKROTIK_HOST=192.168.86.1
MIKROTIK_PORT=22
MIKROTIK_USER=automation
MIKROTIK_PASS=changeme

# --- NUT (UPS monitoring) ---
# ~/.secrets/nut.env
NUT_ADMIN_PASS=changeme
NUT_UPSMON_PASS=changeme

# --- Proxmox Cluster ---
# ~/.secrets/proxmox.env
# SSH access via key (~/.ssh/id_ed25519)
PVE_IP_0=changeme
PVE_IP_1=changeme
PVE_IP_2=changeme
PVE_IP_3=changeme
PVE_IP_4=changeme
PVE_USER=root
QNAP_IP=changeme
